<?xml version="1.0" encoding="utf-8"?>
<!--
  AndroidManifest.xml
  Fichier de déclaration de l'application : équivalent du fichier spec RPM/deb.
  Déclare les permissions, activités, services et providers de l'application.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions réseau pour la synchronisation Wi-Fi avec le PC -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Accès aux fichiers partagés (pour ouvrir un .tc depuis le gestionnaire de fichiers) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Android 10+ : accès complet au stockage externe (images dans _files/) -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <!-- Android 13+ : permission granulaire -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- Notification pour WorkManager (synchronisation en arrière-plan) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:name=".TellicoViewerApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TellicoViewer"
        android:largeHeap="true">

        <!-- Activité principale : point d'entrée unique (Single Activity Architecture) -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.TellicoViewer">

            <!-- Lance l'app depuis le lanceur Android -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Ouvre les fichiers .tc depuis le gestionnaire de fichiers ou un partage -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="file" android:mimeType="application/zip" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" />
                <data android:mimeType="application/octet-stream" />
            </intent-filter>
        </activity>

        <!-- FileProvider : partage sécurisé de fichiers entre apps (Android 7+) -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

        <!-- WorkManager : service de synchronisation planifié -->
        <service
            android:name=".sync.SyncForegroundService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

    </application>
</manifest>
